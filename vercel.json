{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": null,
  "buildCommand": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "maxDuration": 10,
      "includeFiles": ["bloodmap_api/**"]
    }
  },
  "rewrites": [
    {
      "source": "/(.*\\.(?:css|js|png|jpg|jpeg|svg|webp|ico|woff|woff2|eot|ttf|json|txt|xml))$",
      "destination": "/bloodmap_api/public/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.php"
    }
  ]
}
